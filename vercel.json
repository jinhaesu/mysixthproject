{
  "installCommand": "cd frontend && npm install",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/out",
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/HR/(.*)", "dest": "https://frontend-vert-theta-99.vercel.app/HR/$1" },
    { "src": "/HR", "dest": "https://frontend-vert-theta-99.vercel.app/HR" },
    { "handle": "filesystem" }
  ]
}
